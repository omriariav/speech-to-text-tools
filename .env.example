TOOLS_DIR="/path/to/speech-to-text-tools"
VENV_DIR="$TOOLS_DIR/whisper-env"
OUTPUT_DIR="/path/to/output/transcriptions"
LOG_FILE="$OUTPUT_DIR/auto_transcribe.log"

# Transcription engine: mlx-whisper (Apple Silicon, fastest), faster-whisper
# (cross-platform, fast), or openai-whisper (CPU, original/slowest).
# Leave empty to auto-detect: MLX on Apple Silicon when installed, else
# faster-whisper, else openai-whisper. Only pin explicitly if you know the
# chosen engine is installed in your venv.
TRANSCRIPTION_ENGINE=""

# HuggingFace token for Pyannote diarization models (gated).
# Get one at https://huggingface.co/settings/tokens and accept the model terms at
# https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=""

ENABLE_FAST=true
FAST_MODEL="large"
ENABLE_DIARIZATION=true
DIARIZE_MODEL="large"

# Which language(s) to transcribe per recording. Whisper performs poorly
# (slower AND lower quality) when forced to a language that doesn't
# match the audio, so picking just one is usually right. Options:
#   "he"   — Hebrew only (default; matches typical Hebrew meeting workflow)
#   "en"   — English only
#   "both" — run both passes (legacy behavior; ~2x runtime)
TRANSCRIPT_LANGS="he"

# Language gate (optional). When set, transcribe_one.sh runs Whisper language
# detection on several short windows of audio and SKIPS the job if NONE of them
# match. Useful when Folder Actions enqueue every Meet recording but you only
# care about Hebrew (or English) meetings.
# Leave empty to disable gating and transcribe every job.
LANGUAGE_GATE=""
# Model used for language detection. Defaults to FAST_MODEL so no extra
# weights need to be downloaded. Override to "tiny"/"base" for faster
# detection at the cost of an additional model download.
DETECT_MODEL=""
DETECT_SECONDS=30
# Start offsets (seconds) sampled for the language gate. Multiple windows make
# the gate robust to non-matching openings (silence before others join, an
# English "can you hear me?"): the gate passes as soon as ANY window is the gate
# language, and a sample with no detectable speech is treated as "undetermined"
# and transcribed rather than skipped. Set a single value (e.g. "0") to restore
# front-of-file-only detection.
DETECT_OFFSETS="0,90,180"

# Queue settings for auto_transcribe_meet.sh + auto_transcribe_worker.sh.
# Folder Action drops land here; a single worker drains them serially so
# multiple files in flight don't load multiple MLX models at once and OOM.
QUEUE_DIR="$OUTPUT_DIR/.queue"
# Seconds the worker waits after the queue empties before exiting. Lets a
# multi-file drop coalesce without leaving an idle worker around forever.
WORKER_IDLE_GRACE_SECONDS=5
# Seconds between Folder Action enqueue and actual processing. Google Drive
# Meet recordings can appear before Drive can serve their bytes reliably.
TRANSCRIPTION_START_DELAY_SECONDS=600
# Apply the start delay only to inputs whose absolute path contains this
# substring. Default scopes the wait to Google Drive File Provider paths.
TRANSCRIPTION_START_DELAY_PATH_SUBSTRING="/Library/CloudStorage/GoogleDrive-"

# --- Drive-API poller (fetch_drive_recordings.sh) ---
# Pulls Meet recordings directly over the Drive API (via the `gws` CLI) instead
# of waiting for Google Drive File Stream to materialize the local placeholder
# — which is unreliable ("Operation not permitted", placeholders that never
# download). This is the trigger for the Meet Recordings folder; run hourly via
# a LaunchAgent (see com.speech-to-text-tools.drivepoll.plist.example).
#
# Drive folder ID to poll. Leave EMPTY in this template and set it only in your
# local .env — do not commit a real folder ID.
DRIVE_FOLDER_ID=""
# Where downloaded recordings are staged before transcription. Must NOT contain
# the TRANSCRIPTION_START_DELAY_PATH_SUBSTRING, so the start-delay is skipped
# (the file is already fully local).
STAGING_DIR="$OUTPUT_DIR/.staging"
# Per-Drive-file-ID ledger; each recording is fetched + enqueued exactly once.
DRIVE_LEDGER_DIR="$OUTPUT_DIR/.drive_done"
# Drain the transcription queue in the Drive poller's foreground process after
# enqueuing new downloads or finding stranded pending jobs. Keep this enabled
# for launchd: detached background workers can be SIGTERM'd when the poll job
# exits.
DRIVE_DRAIN_QUEUE=1
# Prune a staged file once it's done (not pending in the queue) and older than this.
STAGING_RETENTION_SECONDS=7200
# Show a macOS Notification Center summary each time the poller runs, including
# new/enqueued count, already-handled count, and errors. Set to 0 to disable.
DRIVE_NOTIFY=1
# Absolute path to the gws binary (launchd has a minimal PATH). Default: ~/go/bin/gws
# GWS_BIN="$HOME/go/bin/gws"
