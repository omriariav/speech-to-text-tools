TOOLS_DIR="/path/to/speech-to-text-tools"
VENV_DIR="$TOOLS_DIR/whisper-env"
OUTPUT_DIR="/path/to/output/transcriptions"
LOG_FILE="$OUTPUT_DIR/auto_transcribe.log"

# Transcription engine: mlx-whisper (Apple Silicon, fastest), faster-whisper
# (cross-platform, fast), or openai-whisper (CPU, original/slowest).
# Leave empty to auto-detect: MLX on Apple Silicon when installed, else
# faster-whisper, else openai-whisper. Only pin explicitly if you know the
# chosen engine is installed in your venv.
TRANSCRIPTION_ENGINE=""

# HuggingFace token for Pyannote diarization models (gated).
# Get one at https://huggingface.co/settings/tokens and accept the model terms at
# https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=""

ENABLE_FAST=true
FAST_MODEL="large"
ENABLE_DIARIZATION=true
DIARIZE_MODEL="large"

# Which language(s) to transcribe per recording. Whisper performs poorly
# (slower AND lower quality) when forced to a language that doesn't
# match the audio, so picking just one is usually right. Options:
#   "he"   — Hebrew only (default; matches typical Hebrew meeting workflow)
#   "en"   — English only
#   "both" — run both passes (legacy behavior; ~2x runtime)
TRANSCRIPT_LANGS="he"

# Language gate (optional). When set, transcribe_one.sh runs Whisper language
# detection on the first DETECT_SECONDS of audio and SKIPS the job if the
# detected language doesn't match. Useful when Folder Actions enqueue every
# Meet recording but you only care about Hebrew (or English) meetings.
# Leave empty to disable gating and transcribe every job.
LANGUAGE_GATE=""
# Model used for language detection. Defaults to FAST_MODEL so no extra
# weights need to be downloaded. Override to "tiny"/"base" for faster
# detection at the cost of an additional model download.
DETECT_MODEL=""
DETECT_SECONDS=30

# Queue settings for auto_transcribe_meet.sh + auto_transcribe_worker.sh.
# Folder Action drops land here; a single worker drains them serially so
# multiple files in flight don't load multiple MLX models at once and OOM.
QUEUE_DIR="$OUTPUT_DIR/.queue"
# Seconds the worker waits after the queue empties before exiting. Lets a
# multi-file drop coalesce without leaving an idle worker around forever.
WORKER_IDLE_GRACE_SECONDS=5
